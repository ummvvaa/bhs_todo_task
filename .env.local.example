# --- Supabase (клиент, можно публиковать) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (сервер, СЕКРЕТ — НИКОГДА не коммитить, без NEXT_PUBLIC) ---
# Settings → API → service_role key. Обходит RLS, нужен для создания auth-аккаунтов.
SUPABASE_SERVICE_ROLE_KEY=

# --- ИИ-отчёты / LLM (сервер, СЕКРЕТ, без NEXT_PUBLIC) ---
# Формат запросов — OpenAI Chat Completions. Провайдер-независимо:
# переход на OpenAI = смена только этих трёх переменных, код не меняется.
#
# Groq (сейчас, бесплатный тариф):
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
#
# OpenAI (позже):
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# --- Telegram-уведомления (сервер, СЕКРЕТ, без NEXT_PUBLIC) ---
# Токен бота от @BotFather. Используется и для отправки сообщений, и в webhook.
TELEGRAM_BOT_TOKEN=
# (опц.) Секрет webhook: если задан, передаётся в setWebhook (secret_token) и
# проверяется в /api/telegram/webhook (заголовок X-Telegram-Bot-Api-Secret-Token).
# TELEGRAM_WEBHOOK_SECRET=
# (опц., можно публиковать) username бота без @ — для ссылки/инструкции привязки.
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# --- Cron-эндпоинт напоминаний о дедлайнах (сервер, СЕКРЕТ) ---
# Общий секрет: ночной pg_cron вызывает /api/cron/telegram-reminders с этим
# Bearer-токеном, эндпоинт его проверяет. Сгенерируйте длинную случайную строку.
CRON_SECRET=
